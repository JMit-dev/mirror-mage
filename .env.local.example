# 0 = try direct WebRTC first, switch the room to TURN relay if direct connect fails
# 1 = force TURN relay from the start
MIRROR_MAGE_TURN_MODE=0

MIRROR_MAGE_STUN_URLS=stun:stun.relay.metered.ca:80
MIRROR_MAGE_TURN_URLS=turn:standard.relay.metered.ca:80,turn:standard.relay.metered.ca:80?transport=tcp,turn:standard.relay.metered.ca:443,turns:standard.relay.metered.ca:443?transport=tcp
MIRROR_MAGE_TURN_USERNAME=
MIRROR_MAGE_TURN_CREDENTIAL=

MIRROR_MAGE_P2P_CONNECT_TIMEOUT_MS=7000
MIRROR_MAGE_ROOM_META_POLL_MS=1000
MIRROR_MAGE_RELAY_RETRY_MS=1500
